{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "openai": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://api.openai.com/v1",
        "apiKey": "your-api-key-here"
      },
      "models": {
        "gpt-5.4": {},
        "gpt-5.4-nano": {}
      }
    }
  },
  "model": "openai/gpt-5.4",
  "small_model": "openai/gpt-5.4-nano",
  "default_agent": "carocut-orchestrator",
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 8000
  },
  "agent": {
    "build": {
      "disable": true
    },
    "plan": {
      "disable": true
    },
    "carocut-orchestrator": {
      "tools": {
        "*": false,
        "write": true,
        "edit": true,
        "read": true,
        "glob": true,
        "skill": true,
        "task": true,
        "list": true,
        "question": true
      },
      "permission": {
        "task": {
          "*": "deny",
          "carocut-planner": "allow",
          "carocut-media": "allow",
          "carocut-builder": "allow",
          "carocut-reviewer": "allow"
        },
        "skill": {
          "*": "deny",
          "carocut-orchestrator": "allow"
        }
      }
    },
    "carocut-planner": {
      "mode": "subagent",
      "temperature": 1.0,
      "tools": {
        "*": false,
        "read": true,
        "write": true,
        "edit": true,
        "bash": true,
        "glob": true,
        "list": true,
        "skill": true,
        "question": true,
        "material": true
      },
      "permission": {
        "skill": {
          "*": "deny",
          "carocut-planner-*": "allow"
        }
      }
    },
    "carocut-media": {
      "mode": "subagent",
      "tools": {
        "*": false,
        "read": true,
        "write": true,
        "edit": true,
        "bash": true,
        "glob": true,
        "list": true,
        "skill": true,
        "question": true,
        "webfetch": false,
        "task": false
      },
      "permission": {
        "skill": {
          "*": "deny",
          "carocut-media-*": "allow"
        }
      }
    },
    "carocut-builder": {
      "mode": "subagent",
      "temperature": 1.0,
      "tools": {
        "*": false,
        "read": true,
        "write": true,
        "edit": true,
        "bash": true,
        "glob": true,
        "list": true,
        "skill": true,
        "question": true,
      },
      "permission": {
        "skill": {
          "*": "deny",
          "carocut-builder-*": "allow"
        }
      }
    },
    "carocut-reviewer": {
      "mode": "subagent",
      "tools": {
        "*": false,
        "read": true,
        "write": true,
        "edit": true,
        "bash": true,
        "glob": true,
        "list": true,
        "skill": true,
        "question": true,
      },
      "permission": {
        "skill": {
          "*": "deny",
          "carocut-reviewer": "allow",
          "carocut-builder-remotion-ref": "allow"
        }
      }
    }
  },
  "permission": {
    "list": "allow",
    "skill": "allow",
    "webfetch": "deny",
    "bash": {
      "*": "ask",
      "ffmpeg": "allow",
      "ffprobe": "allow"
    },
    "edit": {
      "*": "ask",
      "./workspaces/*": "allow"
    },
    "write": {
      "*": "ask",
      "./workspaces/*": "allow"
    },
    "read": {
      "*": "ask",
      "./workspaces/*": "allow"
    },
    "glob": {
      "*": "ask",
      "./workspaces/*": "allow"
    },
    "grep": {
      "*": "ask",
      "./workspaces/*": "allow"
    },
    "task": {
      "*": "allow"
    },
    "question": "allow"
  },
  "server": {
    "port": 4096,
    "cors": [
      "http://localhost:3000",
      "http://0.0.0.0:3000"
    ]
  }
}
