{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "openai": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://api.openai.com/v1",
        "apiKey": "your-api-key-here"
      },
      "models": {
        "gpt-4o": {},
        "gpt-4o-mini": {}
      }
    }
  },
  "model": "openai/gpt-4o",
  "agent": {
    "carocut-orchestrator": {
      "mode": "primary",
      "model": "openai/gpt-4o",
      "temperature": 1.0,
      "description": "视频制作工作流编排器。当用户请求制作视频、创建 Remotion 项目、或处理视频素材时使用。协调 planner/media/builder/reviewer 四个领域 subagent 完成完整的视频制作流水线。",
      "tools": {
        "write": true,
        "edit": true,
        "read": true,
        "glob": true,
        "skill": true,
        "task": true,
        "question": true,
        "bash": false,
        "env": false,
        "material": false,
        "images_search": false,
        "images_generate": false,
        "images_remove_bg": false,
        "audio_batch_tts": false,
        "audio_tts_single": false,
        "audio_durations": false,
        "audio_search_sfx": false,
        "project_setup": false,
        "project_migrate": false
      },
      "permission": {
        "task": {
          "*": "deny",
          "carocut-planner": "allow",
          "carocut-media": "allow",
          "carocut-builder": "allow",
          "carocut-reviewer": "allow"
        },
        "skill": {
          "*": "deny",
          "carocut-orchestrator": "allow"
        }
      }
    },
    "carocut-planner": {
      "mode": "subagent",
      "model": "openai/gpt-4o",
      "temperature": 1.0,
      "description": "视频制作的素材分析与策划 subagent。负责环境检查（step-0）、素材解析与清点（step-1）、以及完整的制作策划文档生成（step-2）。",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true,
        "glob": true,
        "skill": true,
        "question": true,
        "task": false
      },
      "permission": {
        "skill": {
          "*": "deny",
          "carocut-planner-*": "allow"
        }
      }
    },
    "carocut-media": {
      "mode": "subagent",
      "model": "openai/gpt-4o",
      "temperature": 1.0,
      "description": "视频制作的媒体资源获取 subagent。负责脚本润色去 AI 味（step-3）、视觉素材检索与生成（step-4）、音频素材生成与检索（step-5）。",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true,
        "glob": true,
        "skill": true,
        "question": true,
        "task": false
      },
      "permission": {
        "skill": {
          "*": "deny",
          "carocut-media-*": "allow"
        }
      }
    },
    "carocut-builder": {
      "mode": "subagent",
      "model": "openai/gpt-4o",
      "temperature": 1.0,
      "description": "视频制作的 Remotion 工程实现 subagent。负责 Remotion 项目初始化（step-6）、资产管道建设与 TypeScript 映射生成（step-7）、以及 storyboard 到 React 组件的完整实现（step-8）。",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true,
        "glob": true,
        "skill": true,
        "question": true,
        "task": false
      },
      "permission": {
        "skill": {
          "*": "deny",
          "carocut-builder-*": "allow"
        }
      }
    },
    "carocut-reviewer": {
      "mode": "subagent",
      "model": "openai/gpt-4o",
      "temperature": 1.0,
      "description": "视频制作的预览审查与最终渲染 subagent。负责启动 Remotion Studio 预览、根据用户反馈协调修改、调试运行时问题、以及最终渲染输出。",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true,
        "glob": true,
        "skill": true,
        "question": true,
        "task": false
      },
      "permission": {
        "skill": {
          "*": "deny",
          "carocut-reviewer": "allow",
          "carocut-builder-remotion-ref": "allow"
        }
      }
    }
  },
  "permission": {
    "skill": { "*": "allow" },
    "bash": { "*": "allow" },
    "edit": { "*": "allow" },
    "write": { "*": "allow" },
    "read": { "*": "allow" },
    "glob": { "*": "allow" },
    "grep": { "*": "allow" },
    "task": { "*": "allow" },
    "question": "allow"
  },
  "server": {
    "port": 4096,
    "cors": ["http://localhost:3000", "http://0.0.0.0:3000"]
  }
}
